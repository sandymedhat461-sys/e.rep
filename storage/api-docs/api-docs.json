{
    "openapi": "3.0.0",
    "info": {
        "title": "E-Rep API",
        "description": "E-Rep Pharmaceutical Platform API",
        "version": "1.0.0"
    },
    "paths": {
        "/api/auth/admin/register": {
            "post": {
                "summary": "Register a new admin",
                "operationId": "6aae6dd32889fe18183fb946a184f9da",
                "responses": {
                    "201": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/doctor/meetings": {
            "post": {
                "tags": [
                    "Doctor Meetings"
                ],
                "summary": "Create a meeting request",
                "operationId": "2c2d2d91afbd85a12733a302d0c89850",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "rep_id",
                                    "date",
                                    "time",
                                    "type"
                                ],
                                "properties": {
                                    "rep_id": {
                                        "type": "integer"
                                    },
                                    "date": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "time": {
                                        "type": "string"
                                    },
                                    "type": {
                                        "type": "string",
                                        "enum": [
                                            "Online",
                                            "Offline"
                                        ]
                                    },
                                    "notes": {
                                        "type": "string",
                                        "nullable": true,
                                        "maxLength": 5000
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Meeting created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "properties": {
                                                "meeting": {
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Doctor Meetings",
            "description": "Doctor Meetings"
        }
    ]
}